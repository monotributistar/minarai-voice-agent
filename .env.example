# Orchestrator
PORT=8787
STT_URL=http://stt:9001/transcribe
STT_PROVIDER=groq
TTS_URL=http://tts:9002/speak
TTS_PROVIDER=local
MAX_AUDIO_BYTES=8388608
MAX_AUDIO_SECONDS=30
TMP_DIR=/tmp
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider (Groq OpenAI-compatible)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=replace-me

# Groq STT (uses same API key by default if GROQ_API_KEY is empty)
GROQ_API_KEY=
GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_URL=https://api.groq.com/openai/v1/audio/speech
GROQ_TTS_MODEL=playai-tts
GROQ_TTS_VOICE=Fritz-PlayAI
GROQ_TTS_INPUT_MAX_CHARS=180
GROQ_TTS_NON_EN_STRATEGY=local

# STT
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=float16
WHISPER_DEVICE=auto

# TTS (put your piper models under voice-agent/tts/voices)
PIPER_VOICE_ES=/app/voices/es/es_ES-sharvard-medium.onnx
PIPER_VOICE_EN=/app/voices/en/en_US-joe-medium.onnx
