# Orchestrator
PORT=8787
STT_URL=http://stt:9001/transcribe
TTS_URL=http://tts:9002/speak
MAX_AUDIO_BYTES=8388608
MAX_AUDIO_SECONDS=30
TMP_DIR=/tmp
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=replace-me

# STT
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=float16
WHISPER_DEVICE=auto

# TTS (put your piper models under voice-agent/tts/voices)
PIPER_VOICE_ES=/app/voices/es/es_AR-voice.onnx
PIPER_VOICE_EN=/app/voices/en/en_US-voice.onnx
